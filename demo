<script>
// Clock
function tick() {
  const now = new Date();
  document.getElementById('clockDisplay').textContent =
    now.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
}
tick(); setInterval(tick, 1000);

// Role switcher
function switchRole(role) {
  document.querySelectorAll('.view').forEach(v => { v.style.display = 'none'; v.classList.remove('active'); });
  document.querySelectorAll('.rb-tab').forEach(t => t.classList.remove('active'));

  const el = document.getElementById('view-' + role);
  el.style.display = 'flex';
  el.classList.add('active');

  const tabs = document.querySelectorAll('.rb-tab');
  const map = { admin: 0, csr: 1, counter: 2 };
  tabs[map[role]].classList.add('active');
}
</script>
