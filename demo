<style>
/* ── TOKENS ── */
:root {
  --g:        #41af00;
  --g-dim:    rgba(65,175,0,.12);
  --g-border: rgba(65,175,0,.28);
  --dark:     #111213;
  --panel:    #181a1b;
  --card:     #1f2122;
  --card2:    #262829;
  --border:   rgba(255,255,255,.07);
  --border2:  rgba(255,255,255,.12);
  --text:     #e8e6e1;
  --muted:    rgba(232,230,225,.48);
  --muted2:   rgba(232,230,225,.24);
  --amber:    #e8a020;
  --red:      #e05050;
  --blue:     #4a9eff;

  --font-body:  'IBM Plex Sans', sans-serif;
  --font-serif: 'DM Serif Display', serif;
  --font-mono:  'IBM Plex Mono', monospace;
}

* { margin:0; padding:0; box-sizing:border-box; }
html, body { width:100%; min-height:100vh; background:var(--dark); color:var(--text); font-family:var(--font-body); font-size:14px; line-height:1.5; }

/* ── ROLE SWITCHER ── */
.role-bar {
  position:fixed; top:0; left:0; right:0; height:52px; z-index:200;
  background:rgba(17,18,19,.96); border-bottom:1px solid var(--border);
  backdrop-filter:blur(12px);
  display:flex; align-items:center; padding:0 24px; gap:32px;
}
.rb-brand { display:flex; align-items:center; gap:10px; margin-right:auto; }
.rb-logo { width:26px; height:26px; background:var(--g); border-radius:6px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.rb-logo svg { width:14px; height:14px; fill:white; }
.rb-name { font-family:var(--font-serif); font-size:17px; letter-spacing:.2px; }
.rb-name span { color:var(--g); }
.rb-tabs { display:flex; gap:4px; }
.rb-tab {
  padding:6px 18px; border-radius:6px; border:1px solid transparent;
  font-size:13px; font-weight:500; cursor:pointer; font-family:var(--font-body);
  color:var(--muted); transition:all .2s; background:none;
}
.rb-tab:hover { color:var(--text); background:var(--card); }
.rb-tab.active { color:var(--g); border-color:var(--g-border); background:var(--g-dim); }
.rb-time { font-family:var(--font-mono); font-size:12px; color:var(--muted2); margin-left:auto; }

/* ── LAYOUT ── */
.app { display:flex; min-height:100vh; padding-top:52px; }

/* SIDEBAR */
.sidebar {
  width:220px; min-height:calc(100vh - 52px);
  background:var(--panel); border-right:1px solid var(--border);
  display:flex; flex-direction:column;
  position:fixed; top:52px; left:0; bottom:0;
  overflow-y:auto;
}
.sb-section { padding:20px 14px 8px; }
.sb-section-label { font-size:10px; letter-spacing:2px; text-transform:uppercase; color:var(--muted2); font-weight:600; padding:0 8px; margin-bottom:6px; }
.sb-item {
  display:flex; align-items:center; gap:10px; padding:9px 10px;
  border-radius:7px; cursor:pointer; color:var(--muted);
  font-size:13px; font-weight:500; transition:all .18s;
  border:1px solid transparent;
}
.sb-item:hover { color:var(--text); background:var(--card); }
.sb-item.active { color:var(--g); background:var(--g-dim); border-color:var(--g-border); }
.sb-item .si-icon { width:18px; text-align:center; font-size:15px; flex-shrink:0; }
.sb-item .si-badge {
  margin-left:auto; background:var(--g); color:white;
  font-size:10px; font-weight:700; padding:1px 7px; border-radius:10px;
  font-family:var(--font-mono);
}
.sb-item .si-badge.amber { background:var(--amber); }
.sb-footer { margin-top:auto; padding:14px; border-top:1px solid var(--border); }
.sb-user { display:flex; align-items:center; gap:10px; }
.sb-avatar { width:32px; height:32px; border-radius:50%; background:var(--g-dim); border:1.5px solid var(--g-border); display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:600; color:var(--g); flex-shrink:0; }
.sb-user-info .sui-name { font-size:13px; font-weight:600; }
.sb-user-info .sui-role { font-size:11px; color:var(--muted); }

/* MAIN */
.main { margin-left:220px; flex:1; padding:28px 32px; min-height:calc(100vh - 52px); }

/* PAGE HEADER */
.page-header { margin-bottom:24px; }
.ph-eyebrow { font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--g); font-weight:600; margin-bottom:6px; }
.ph-title { font-family:var(--font-serif); font-size:26px; color:var(--text); line-height:1.2; }
.ph-sub { font-size:13px; color:var(--muted); margin-top:4px; }
.ph-row { display:flex; align-items:flex-end; justify-content:space-between; gap:16px; }

/* CARDS & PANELS */
.card { background:var(--card); border:1px solid var(--border); border-radius:10px; }
.card-header { padding:14px 18px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
.ch-title { font-size:13px; font-weight:600; }
.ch-action { font-size:12px; color:var(--g); cursor:pointer; font-weight:500; }
.card-body { padding:16px 18px; }

/* STAT CARDS */
.stats-row { display:grid; gap:16px; margin-bottom:20px; }
.stats-4 { grid-template-columns:repeat(4,1fr); }
.stats-3 { grid-template-columns:repeat(3,1fr); }
.stat-card { background:var(--card); border:1px solid var(--border); border-radius:10px; padding:18px 20px; }
.stat-card.green { border-color:var(--g-border); background:rgba(65,175,0,.05); }
.stat-card.amber { border-color:rgba(232,160,32,.25); background:rgba(232,160,32,.04); }
.sc-label { font-size:11px; color:var(--muted); font-weight:500; margin-bottom:8px; text-transform:uppercase; letter-spacing:.5px; }
.sc-val { font-family:var(--font-serif); font-size:30px; color:var(--text); line-height:1; }
.stat-card.green .sc-val { color:var(--g); }
.stat-card.amber .sc-val { color:var(--amber); }
.sc-delta { font-size:11px; color:var(--muted); margin-top:6px; }
.sc-delta .up { color:var(--g); font-weight:600; }
.sc-delta .dn { color:var(--red); font-weight:600; }

/* TABLES */
.data-table { width:100%; border-collapse:collapse; }
.data-table th { font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.8px; color:var(--muted); padding:10px 14px; border-bottom:1px solid var(--border); text-align:left; }
.data-table td { font-size:13px; padding:11px 14px; border-bottom:1px solid var(--border); vertical-align:middle; }
.data-table tr:last-child td { border-bottom:none; }
.data-table tr:hover td { background:rgba(255,255,255,.02); }

/* BADGES */
.badge { display:inline-flex; align-items:center; gap:4px; font-size:11px; font-weight:600; padding:3px 10px; border-radius:5px; font-family:var(--font-mono); }
.badge.green { background:rgba(65,175,0,.12); color:var(--g); border:1px solid rgba(65,175,0,.2); }
.badge.amber { background:rgba(232,160,32,.1); color:var(--amber); border:1px solid rgba(232,160,32,.2); }
.badge.red { background:rgba(224,80,80,.1); color:var(--red); border:1px solid rgba(224,80,80,.2); }
.badge.muted { background:rgba(255,255,255,.05); color:var(--muted); border:1px solid var(--border); }
.badge.blue { background:rgba(74,158,255,.1); color:var(--blue); border:1px solid rgba(74,158,255,.2); }

/* PROGRESS BAR */
.prog-bar { height:5px; background:var(--card2); border-radius:3px; overflow:hidden; }
.prog-fill { height:100%; background:var(--g); border-radius:3px; transition:width .4s; }
.prog-fill.amber { background:var(--amber); }

/* BUTTONS */
.btn { display:inline-flex; align-items:center; gap:6px; padding:8px 16px; border-radius:7px; font-size:13px; font-weight:500; cursor:pointer; font-family:var(--font-body); transition:all .18s; border:1px solid transparent; }
.btn-primary { background:var(--g); color:white; border-color:var(--g); }
.btn-primary:hover { background:rgba(65,175,0,.85); }
.btn-ghost { background:transparent; color:var(--muted); border-color:var(--border2); }
.btn-ghost:hover { color:var(--text); border-color:var(--border2); background:var(--card2); }
.btn-sm { padding:5px 12px; font-size:12px; }
.btn-danger { background:rgba(224,80,80,.1); color:var(--red); border-color:rgba(224,80,80,.25); }
.btn-danger:hover { background:rgba(224,80,80,.18); }

/* INPUT */
.input-field { background:var(--card2); border:1px solid var(--border2); border-radius:7px; padding:8px 12px; font-size:13px; color:var(--text); font-family:var(--font-body); outline:none; width:100%; }
.input-field:focus { border-color:var(--g-border); }
.input-field::placeholder { color:var(--muted2); }

/* NOTIF DOT */
.notif-dot { width:8px; height:8px; border-radius:50%; background:var(--g); flex-shrink:0; }
.notif-dot.amber { background:var(--amber); }
.notif-dot.red { background:var(--red); }

/* TICKET CARD */
.ticket-card {
  background:var(--card); border:1px solid var(--border); border-radius:10px;
  padding:14px 16px; margin-bottom:10px; cursor:pointer;
  transition:border-color .18s, background .18s;
  display:flex; gap:12px; align-items:flex-start;
}
.ticket-card:hover { border-color:var(--border2); background:var(--card2); }
.ticket-card.t1 { border-left:3px solid var(--g); }
.ticket-card.t2 { border-left:3px solid var(--amber); }
.ticket-card.t3 { border-left:3px solid var(--border2); }
.tc-left { flex:1; }
.tc-name { font-size:14px; font-weight:600; margin-bottom:3px; }
.tc-meta { font-size:12px; color:var(--muted); margin-bottom:8px; }
.tc-medicine { font-size:12px; font-family:var(--font-mono); color:var(--text); background:var(--card2); display:inline-block; padding:3px 9px; border-radius:5px; border:1px solid var(--border2); margin-right:4px; margin-bottom:4px; }
.tc-right { display:flex; flex-direction:column; align-items:flex-end; gap:8px; flex-shrink:0; }
.tc-days { font-family:var(--font-mono); font-size:11px; color:var(--muted); }

/* GRID LAYOUTS */
.grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
.grid-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; }
.grid-65-35 { display:grid; grid-template-columns:1fr .55fr; gap:20px; }
.grid-35-65 { display:grid; grid-template-columns:.55fr 1fr; gap:20px; }

/* UPLOAD ZONE */
.upload-zone {
  border:2px dashed var(--border2); border-radius:10px; padding:32px;
  text-align:center; transition:all .2s; cursor:pointer;
}
.upload-zone:hover { border-color:var(--g-border); background:var(--g-dim); }
.uz-icon { font-size:32px; margin-bottom:10px; }
.uz-title { font-size:14px; font-weight:600; margin-bottom:4px; }
.uz-desc { font-size:12px; color:var(--muted); }

/* ORDER CARD */
.order-card { background:var(--card); border:1px solid var(--border); border-radius:10px; padding:16px; margin-bottom:10px; }
.order-card.pending { border-color:rgba(232,160,32,.3); }
.order-card.accepted { border-color:rgba(65,175,0,.3); }
.oc-header { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:10px; }
.oc-id { font-family:var(--font-mono); font-size:12px; color:var(--muted); }
.oc-patient { font-size:14px; font-weight:600; margin-top:2px; }
.oc-meta { font-size:12px; color:var(--muted); }
.oc-medicines { margin:10px 0; display:flex; flex-wrap:wrap; gap:6px; }
.oc-actions { display:flex; gap:8px; margin-top:12px; padding-top:12px; border-top:1px solid var(--border); }

/* RULE CARD */
.rule-card { background:var(--card2); border:1px solid var(--border); border-radius:8px; padding:14px 16px; margin-bottom:8px; display:flex; align-items:center; gap:14px; }
.rc-icon { font-size:18px; flex-shrink:0; }
.rc-body { flex:1; }
.rc-title { font-size:13px; font-weight:600; margin-bottom:2px; }
.rc-desc { font-size:12px; color:var(--muted); }
.rc-control { flex-shrink:0; }
.toggle { width:38px; height:20px; background:var(--card2); border:1.5px solid var(--border2); border-radius:10px; position:relative; cursor:pointer; transition:all .2s; }
.toggle.on { background:var(--g); border-color:var(--g); }
.toggle::after { content:''; position:absolute; top:2px; left:2px; width:12px; height:12px; border-radius:50%; background:white; transition:left .2s; }
.toggle.on::after { left:20px; }

/* SECTION DIVIDER */
.section-gap { margin-bottom:20px; }

/* IN-APP NOTIFICATION */
.notif-list { display:flex; flex-direction:column; gap:8px; }
.notif-item { display:flex; gap:10px; align-items:flex-start; padding:11px 13px; background:var(--card2); border-radius:8px; border:1px solid var(--border); }
.ni-dot { flex-shrink:0; margin-top:5px; }
.ni-body { flex:1; }
.ni-title { font-size:13px; font-weight:600; margin-bottom:2px; }
.ni-desc { font-size:12px; color:var(--muted); }
.ni-time { font-size:11px; color:var(--muted2); font-family:var(--font-mono); flex-shrink:0; }

/* VIEWS */
.view { display:none; }
.view.active { display:block; }

/* SCROLLABLE LIST */
.scroll-list { max-height:340px; overflow-y:auto; padding-right:4px; }
.scroll-list::-webkit-scrollbar { width:3px; }
.scroll-list::-webkit-scrollbar-thumb { background:var(--border2); border-radius:2px; }

/* PHONE DISPLAY */
.phone-display { font-family:var(--font-mono); font-size:13px; color:var(--blue); background:rgba(74,158,255,.07); border:1px solid rgba(74,158,255,.15); border-radius:6px; padding:5px 10px; display:inline-block; cursor:default; }

/* MINI CHART BARS */
.mini-bars { display:flex; align-items:flex-end; gap:3px; height:48px; }
.mini-bar { flex:1; background:var(--g-dim); border-radius:3px 3px 0 0; border:1px solid var(--g-border); transition:height .4s; }
.mini-bar:hover { background:var(--g); }

/* UPLOAD STATUS */
.upload-status { display:flex; flex-direction:column; gap:8px; }
.us-row { display:flex; align-items:center; gap:10px; padding:9px 12px; background:var(--card2); border-radius:7px; border:1px solid var(--border); }
.us-counter { font-size:13px; font-weight:500; flex:1; }
.us-date { font-family:var(--font-mono); font-size:11px; color:var(--muted); }
.us-status { font-size:11px; font-weight:600; }
.us-status.ok { color:var(--g); }
.us-status.miss { color:var(--red); }
.us-status.late { color:var(--amber); }

/* PATIENT PHONE ROW */
.patient-phone-row { display:flex; align-items:center; gap:8px; margin-top:6px; }
</style>
</head>
